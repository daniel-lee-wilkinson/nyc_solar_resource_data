solar_resource_df %>%
mutate(month = factor(month, levels = month.abb)) %>%
arrange(month) %>%
ggplot(aes(x = month, y = avg_dni)) +
geom_line(group = 1) +
geom_point() +
theme_bw()
library(tidyverse)
library(httr)
library(jsonlite)
# x axis labels ordered alphabetically
solar_resource_df %>%
arrange(month) %>%
ggplot(aes(x = month, y = avg_dni)) +
geom_line(group = 1) +
geom_point() +
theme_bw() + labs(x = "Month",y="Average DNI")
# order the x axis labels by month abbreviation (Jan--> December)
solar_resource_df %>%
mutate(month = factor(month, levels = month.abb)) %>%
arrange(month) %>%
ggplot(aes(x = month, y = avg_dni)) +
geom_line(group = 1) +
geom_point() +
theme_bw() +labs(x="Month",y="Average DNI")
