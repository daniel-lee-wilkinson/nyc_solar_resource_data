# Introduction

- Data source: Data Gov API - Solar Resource data - solar data types for given US locations: `<https://developer.nrel.gov/docs/solar/solar-resource-v1/>`
- Output fields of interest: avg_dni, avg_lat_tilt, avg_ghi
- Goal: extract solar resource data for New York City in JSON format and convert it to a dataframe

# Project Set-Up

```{r set-up, warning=FALSE, message=FALSE}
library(tidyverse)
library(httr)
library(jsonlite)

```

```{r echo=FALSE}
my_api = "Y4bmMjaDbGd2fm9QpgneYbw8P8VltABqDMx5J6dZ"

```

# Connect to API

```{r}
url <- "https://developer.nrel.gov/api/solar/solar_resource/v1.json"
# parameters to retrieve New York data
parameters_list <- list(api_key = my_api, lat = 41, lon = -75)

# API requests
response <- GET(url, query = parameters_list)

# Check the status of the request
status <- status_code(response)

# Extracting content
content <- content(response,"text")
```

# Parsing the JSON into an R Object

```{r}
json_lists <- fromJSON(content) # mapping of json to R object
str(json_lists) # data structure
# extract output list from json_lists
outputs <- json_lists$outputs
# extract monthly vector `monthly` from avg_dni, avg_ghi and avg_lat_tilt
dni_monthly <- outputs$avg_dni$monthly
ghi_monthly <- outputs$avg_ghi$monthly
lat_tilt_monthly <- outputs$avg_lat_tilt$monthly

# create tibble from vectors, months column with month abbreviations
# on left-most column, manually adding column names
dataframe <- tibble::tibble("month" = month.abb, "avg_dni" = dni_monthly, "avg_ghi" = ghi_monthly, "avg_lat_tilt" = lat_tilt_monthly)
#display dataframe
dataframe 

```

--> This tibble dataframe contains lists with 1 value in each.

# Convert tibble to a dataframe

```{r}
outputs_list <- json_lists$outputs
# simplify the outputs list - remove all sub-hierarchies
# from lists and return simple named vector, using unlist()
simplified_outputs_list <- unlist(outputs_list)
# restructure the vector into a 2d object (matrix())
data_matrix <-matrix(data=simplified_outputs_list, nrow=13)
# remove annual values from last row
data_matrix = data_matrix[-1,]
# convert matrix to a dataframe
df <- as.data.frame(data_matrix)
# need to append the month back, add back column names and
# put month as first column
df$month <- month.abb
names(df) <- c("avg_dni","avg_ghi","avg_lat_tilt","month")
df <- df %>% select(month, everything())

```

# Putting it all together

```{r}
# combine the above steps into a single function
solar_api_json_get_df <- function(endpoint, queries = list()) {
  url <- modify_url("https://developer.nrel.gov", path = endpoint)
  response <- GET(url, query = queries)
  if (http_error(response)) {
    print(status_code(response))
    print(http_status(response))
    stop("Something went wrong.", call. = FALSE)
  }
  if (http_type(response) != "application/json") {
    stop("API did not return json", call. = FALSE)
  }
  json_text <- content(response, "text")
  json_lists <- jsonlite::fromJSON(json_text)
  outputs <- json_lists$outputs
    df <- outputs[c("avg_dni", "avg_ghi", "avg_lat_tilt")] %>%
    lapply(function(x) unlist(x$monthly)) %>%
    as.data.frame() %>%
    `rownames<-`(NULL) %>%
    mutate(month = month.abb) %>%
    select(month, everything())
  df
}

# apply the function
solar_resource_df <- solar_api_json_get_df("api/solar/solar_resource/v1.json", parameters_list)
solar_resource_df
```

# Visualizing New Yord City Solar Resource Data

```{r}
# x axis labels ordered alphabetically
solar_resource_df %>%
  arrange(month) %>%
  ggplot(aes(x = month, y = avg_dni)) +
  geom_line(group = 1) +
  geom_point() + 
  theme_bw() + labs(x = "Month",y="Average DNI")
```

```{r}
# order the x axis labels by month abbreviation (Jan--> December)
solar_resource_df %>%
  mutate(month = factor(month, levels = month.abb)) %>%
  arrange(month) %>%
  ggplot(aes(x = month, y = avg_dni)) +
  geom_line(group = 1) +
  geom_point() + 
  theme_bw() +labs(x="Month",y="Average DNI")

```

The operation `solar_resource_df %>%
  mutate(month = factor(month, levels = month.abb))` converts the month into a factor, uses the month abbrevations, and orders chronologically. Without the factor, the month abbreviations are alphabetical on the plot instead.
  
The figures show that, in New York, the maximum average DNI is in July (summer) and the minimum average is in November (winter), matching expectations
  